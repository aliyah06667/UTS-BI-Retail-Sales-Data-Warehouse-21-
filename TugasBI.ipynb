    {
      "cell_type": "markdown",
      "source": [
        "**Tahap Merging**"
      ],
      "metadata": {
        "id": "7fhUkFAD99IS"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "fact_sales = pd.read_csv('/content/drive/MyDrive/Tugas BI/fact_sales.csv')\n",
        "dim_customer = pd.read_csv('/content/drive/MyDrive/Tugas BI/dim_customer.csv')\n",
        "dim_product = pd.read_csv('/content/drive/MyDrive/Tugas BI/dim_product.csv')\n",
        "dim_location = pd.read_csv('/content/drive/MyDrive/Tugas BI/dim_location.csv')\n",
        "dim_date = pd.read_csv('/content/drive/MyDrive/Tugas BI/dim_date.csv')\n",
        "\n",
        "# Gabungkan Penjualan dengan Produk\n",
        "master_df = fact_sales.merge(dim_product, on='product id', how='left')\n",
        "\n",
        "# Gabungkan dengan Pelanggan (Ini akan memasukkan kolom city & state ke master_df)\n",
        "master_df = master_df.merge(dim_customer, on='customer id', how='left')\n",
        "\n",
        "# Gabungkan dengan Waktu\n",
        "master_df = master_df.merge(dim_date, on='order date', how='left')\n",
        "\n",
        "print(\"Kolom yang tersedia sekarang:\", master_df.columns.tolist())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "oEjYms0Gxx7L",
        "outputId": "ca37fe47-af7b-4633-e85a-9c4b0657873b"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Kolom yang tersedia sekarang: ['order id', 'order date', 'customer id', 'product id', 'sales', 'product name', 'category', 'sub-category', 'customer name', 'segment', 'day', 'month', 'year', 'quarter']\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**1. Tren Penjualan per Bulan**"
      ],
      "metadata": {
        "id": "OHmYEXaUx-R9"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# Persiapan data: Mengurutkan berdasarkan tahun dan bulan\n",
        "monthly_sales = master_df.groupby(['year', 'month'])['sales'].sum().reset_index()\n",
        "monthly_sales = monthly_sales.sort_values(['year', 'month'])\n",
        "\n",
        "# Membuat label periode (format: YYYY-MM)\n",
        "monthly_sales['period'] = monthly_sales['year'].astype(str) + '-' + monthly_sales['month'].astype(str).str.zfill(2)\n",
        "\n",
        "plt.figure(figsize=(15, 6))\n",
        "sns.lineplot(data=monthly_sales, x='period', y='sales', marker='o', palette='mako', linewidth=2.5)\n",
        "plt.title('Tren Penjualan Bulanan (Total Sales)', fontsize=14)\n",
        "plt.xticks(rotation=45)\n",
        "plt.xlabel('Periode (Tahun-Bulan)')\n",
        "plt.ylabel('Total Penjualan')\n",
        "plt.grid(True, linestyle='--', alpha=0.6)\n",
        "plt.show()"
